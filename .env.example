# ═══════════════════════════════════════════════════════════════════
# Malibu — Production ACP Agent Harness
# Copy this file to .env and fill in your values.
#
# All variables map 1-to-1 with fields in malibu/config.py (Settings).
# ═══════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://malibu:malibu@localhost:5432/malibu
# For development with SQLite (no PostgreSQL required):
# DATABASE_URL=sqlite+aiosqlite:///./malibu.db

# ── LLM Provider ─────────────────────────────────────────────────
# Model string in LangChain format: "provider:model-name"
# Examples: openai:gpt-4o, anthropic:claude-sonnet-4-5
LLM_MODEL=openai:gpt-4o
# Your API key for the LLM provider.
# If blank, falls back to OPENAI_API_KEY / ANTHROPIC_API_KEY env vars.
LLM_API_KEY=sk-...
# Optional: base URL for proxies or custom endpoints
# LLM_BASE_URL=https://api.openai.com/v1

# ── Authentication ────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── Server ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR
STDIO_BUFFER_LIMIT_BYTES=52428800
# Default: 50MB (50 * 1024 * 1024)

# ── Security ──────────────────────────────────────────────────────
# JSON list of allowed base directories for file operations.
# If empty, defaults to the session's cwd.
ALLOWED_PATHS=
# Maximum file size for read/write operations (bytes).
MAX_FILE_SIZE=10485760

# ── API Gateway (FastAPI scaffold) ────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Telemetry ─────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=malibu
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── LangChain/LangSmith (not Malibu settings, but useful) ────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=malibu-dev
LANGSMITH_API_KEY=lsv2_pt_...


